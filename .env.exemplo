# ================================================================
# ExpoSite — Arquivo de configuração de ambiente
# Copie: cp .env.exemplo .env
# Preencha os valores reais no .env — nunca commite o .env
# ================================================================

# ---------------------------------------------------------------
# Banco de dados central
# ---------------------------------------------------------------
BD_SENHA_ROOT=senha_root_aqui
BD_USUARIO=exposite_usuario
BD_SENHA=senha_forte_aqui

# ---------------------------------------------------------------
# Redis
# ---------------------------------------------------------------
REDIS_SENHA=senha_redis_aqui

# ---------------------------------------------------------------
# Laravel
# ---------------------------------------------------------------
APP_KEY=base64:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=
APP_URL=https://exposite.com.br
APP_DOMINIO=exposite.com.br
APP_ENV=production
APP_DEBUG=false

# ---------------------------------------------------------------
# Token interno agente → API (gere com: openssl rand -hex 32)
# ---------------------------------------------------------------
API_TOKEN_INTERNO=

# ---------------------------------------------------------------
# Mercado Pago (Fase 2)
# ---------------------------------------------------------------
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ---------------------------------------------------------------
# Telegram (Fase 3)
# ---------------------------------------------------------------
TELEGRAM_WEBHOOK_SECRET=

# ---------------------------------------------------------------
# OpenAI — GPT-4o mini (Fase 3)
# ---------------------------------------------------------------
OPENAI_CHAVE=

# ---------------------------------------------------------------
# Email transacional (Fase 2)
# ---------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@exposite.com.br
MAIL_FROM_NOME=ExpoSite
